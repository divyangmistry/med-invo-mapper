# ─────────────────────────────────────────────────────────────────────────────
#  LOCAL (NON-DOCKER) ENVIRONMENT CONFIG
#  Used by setup.sh / setup.bat when running the native app.
#  This file is copied to .env by the setup script.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama / VLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
VLM_MODEL=qwen2.5vl:7b
VLM_TIMEOUT=120
VLM_TEMPERATURE=0.0

# ── Camera / Capture ─────────────────────────────────────────────────────────
# 'folder'  → watch ./inputs/ directory (drop images here)
# 'live'    → OpenCV USB camera
CAMERA_MODE=folder
CAMERA_INDEX=0
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080
SETTLE_SECONDS=1.8
MOTION_THRESHOLD=500

# ── Database ─────────────────────────────────────────────────────────────────
# Uses a relative path — the launcher sets the CWD to the project root
DATABASE_URL=sqlite:///./db/med_invo.db

# ── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./outputs
INPUT_DIR=./inputs
LOG_DIR=./logs

# ── Agent Behaviour ──────────────────────────────────────────────────────────
RETRY_ON_MISSING_FIELDS=true
MAX_RETRIES=2
LOG_LEVEL=INFO
