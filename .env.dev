# ─────────────────────────────────────────────────────────
#  DEV ENVIRONMENT — Windows local machine
#
#  Ollama runs NATIVELY on Windows (not in Docker).
#  Install from: https://ollama.com/download/windows
#  Then pull model: ollama pull qwen2-vl:7b
#
#  Activate:  copy .env.dev .env
#  Start:     docker compose up -d agent dashboard
# ─────────────────────────────────────────────────────────

# ── Ollama / VLM ─────────────────────────────────────────
# Ollama runs natively on macOS — use localhost
OLLAMA_BASE_URL=http://localhost:11434
VLM_MODEL=qwen2-vl:7b
VLM_TIMEOUT=120
VLM_TEMPERATURE=0.0

# ── Camera / Capture ─────────────────────────────────────
# 'folder' → watch ./inputs/ directory (dev mode, no camera needed)
# 'live'   → OpenCV USB camera (prod mode)
CAMERA_MODE=folder
CAMERA_INDEX=0
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080
SETTLE_SECONDS=1.8
MOTION_THRESHOLD=500

# ── Database ─────────────────────────────────────────────
# Leave unset → config.py auto-resolves to <project_root>/db/med_invo.db
# DATABASE_URL=sqlite:////app/db/med_invo.db

# ── Paths ────────────────────────────────────────────────
# Leave unset → config.py auto-resolves relative to project root
# OUTPUT_DIR=/app/outputs
# INPUT_DIR=/app/inputs
# LOG_DIR=/app/logs

# ── Agent Behaviour ──────────────────────────────────────
RETRY_ON_MISSING_FIELDS=true
MAX_RETRIES=2
LOG_LEVEL=DEBUG
