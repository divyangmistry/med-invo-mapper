# ─────────────────────────────────────────────────────────
#  PROD ENVIRONMENT — Linux server (Ollama in Docker with GPU)
#
#  Activate:  cp .env.prod .env
#  Start:     docker compose --profile prod up -d
# ─────────────────────────────────────────────────────────

# ── Ollama / VLM ─────────────────────────────────────────
# In prod, Ollama runs inside Docker on the same network
OLLAMA_BASE_URL=http://ollama:11434
VLM_MODEL=llava:13b
VLM_TIMEOUT=180
VLM_TEMPERATURE=0.0

# ── Camera / Capture ─────────────────────────────────────
CAMERA_MODE=live
CAMERA_INDEX=0
CAPTURE_WIDTH=3840
CAPTURE_HEIGHT=2160
SETTLE_SECONDS=1.8
MOTION_THRESHOLD=500

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:////app/db/med_invo.db

# ── Paths ────────────────────────────────────────────────
OUTPUT_DIR=/app/outputs
INPUT_DIR=/app/inputs
LOG_DIR=/app/logs

# ── Agent Behaviour ──────────────────────────────────────
RETRY_ON_MISSING_FIELDS=true
MAX_RETRIES=2
LOG_LEVEL=INFO
